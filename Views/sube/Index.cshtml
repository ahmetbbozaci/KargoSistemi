<style>
    .kargo-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .kargo-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }
    .icon-box {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

