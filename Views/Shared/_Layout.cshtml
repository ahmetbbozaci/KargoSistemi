<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Merkez Kargo Lojistik</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 text-danger" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-seam-fill me-2"></i>MERKEZ KARGO
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 fw-medium">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Kargo" asp-action="Index">Gönderi Takip</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Hesaplama" asp-action="Index">Ücret Hesapla</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Sube" asp-action="Index">Şubelerimiz</a>
                        </li>
                    </ul>
                    <div class="d-flex">
                        <a class="btn btn-outline-dark rounded-pill px-4 fw-bold" asp-area="" asp-controller="Auth" asp-action="Login">
                            <i class="bi bi-person-fill me-1"></i> Kurumsal Giriş
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-4 mt-auto">
        <div class="container text-center">
            <small>&copy; @DateTime.Now.Year - Merkez Kargo Yönetim Sistemleri - Tüm Hakları Saklıdır.</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>