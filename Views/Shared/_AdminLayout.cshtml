<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Merkez Kargo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        .sidebar { min-height: 100vh; background-color: #1a2b3c; } 
        .sidebar a, .sidebar button { 
            color: #adb5bd; 
            text-decoration: none; 
            padding: 12px 20px; 
            display: block; 
            border-bottom: 1px solid rgba(255,255,255,0.05); 
            transition: 0.3s;
            width: 100%;
            text-align: left;
            background: none;
            border-left: none; border-right: none; border-top: none;
            font-size: 0.9rem;
        }
        .sidebar a:hover, .sidebar button:hover { background-color: rgba(255,255,255,0.1); color: #fff; }
        .sidebar .active { background-color: #0d6efd; color: white; border-color: #0d6efd; font-weight: bold; }
        
        .logout-btn { color: #ff6b6b !important; }
        .logout-btn:hover { background-color: #c92a2a !important; color: #fff !important; }
        .tracking-wide { letter-spacing: 1px; }
    </style>
</head>
<body class="bg-light">

    <div class="d-flex">
        <!-- SIDEBAR -->
        <div class="sidebar text-white flex-shrink-0 shadow" style="width: 260px;">
            <div class="p-3 text-center border-bottom" style="border-color: rgba(255,255,255,0.1) !important;">
                <h5 class="fw-bold mb-0 tracking-wide text-white">MERKEZ KARGO</h5>
                <small class="text-white-50">Personel Yönetim Paneli</small>
            </div>
            
            <nav class="nav flex-column mt-2">
                
                @if (User.IsInRole("Mudur"))
                {
                    <div class="text-white-50 px-4 py-2 mt-2 small fw-bold text-uppercase" style="font-size: 0.7rem;">Sistem Yönetimi</div>
                    <a asp-controller="Admin" asp-action="Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                        <i class="bi bi-speedometer2 me-3"></i> Genel Bakış
                    </a>
                    <a asp-controller="Admin" asp-action="PersonelEkle" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "PersonelEkle" ? "active" : "")">
                        <i class="bi bi-person-badge-fill me-3"></i> Personel Tanımla
                    </a>
                }

                @if (User.IsInRole("Mudur") || User.IsInRole("Gise"))
                {
                    <div class="text-white-50 px-4 py-2 mt-3 small fw-bold text-uppercase" style="font-size: 0.7rem;">Müşteri İşlemleri</div>
                    <a asp-controller="Musteri" asp-action="MusteriEkle" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Musteri" ? "active" : "")">
                        <i class="bi bi-person-plus-fill me-3"></i> Yeni Müşteri Kaydı
                    </a>
                }

                @if (User.IsInRole("Mudur") || User.IsInRole("Gise"))
                {
                    <div class="text-white-50 px-4 py-2 mt-3 small fw-bold text-uppercase" style="font-size: 0.7rem;">Kargo Operasyon</div>
                    <a asp-controller="Kargo" asp-action="KargoEkle" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "KargoEkle" ? "active" : "")">
                        <i class="bi bi-box-seam-fill me-3"></i> Yeni Kargo Kabulü
                    </a>
                    <a href="#"><i class="bi bi-arrow-left-right me-3"></i> Durum Güncelleme</a>
                }

                @if (User.IsInRole("Mudur") || User.IsInRole("Kurye"))
                {
                    <div class="text-white-50 px-4 py-2 mt-3 small fw-bold text-uppercase" style="font-size: 0.7rem;">Saha & Dağıtım</div>
                    <a asp-controller="Kargo" asp-action="KuryeListesi" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "KuryeListesi" ? "active" : "")">
                        <i class="bi bi-truck me-3"></i> Zimmetli Kargolarım
                    </a>
                    <a href="#"><i class="bi bi-check-circle-fill me-3"></i> Teslimat Onaylama</a>
                }

                <form asp-controller="Auth" asp-action="Logout" method="post" class="mt-4 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                    <button type="submit" class="logout-btn">
                        <i class="bi bi-power me-3"></i> Güvenli Çıkış
                    </button>
                </form>
            </nav>
        </div>

        <!-- ANA İÇERİK ALANI -->
        <div class="flex-grow-1 p-4" style="overflow-y: auto;">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h3 class="fw-bold text-dark m-0">@ViewData["Title"]</h3>
                
                <div class="d-flex align-items-center">
                    <div class="text-end me-3">
                        <div class="fw-bold text-primary" style="font-size: 0.9rem;">@(ViewBag.SubeAdi ?? "Merkez Kargo Şubesi")</div>
                        <small class="text-muted d-flex align-items-center justify-content-end" style="font-size: 0.75rem;">
                            <span class="me-2">@User.Identity?.Name</span>
                            
                            @if (User.IsInRole("Mudur")) { <span class="badge bg-danger rounded-pill">Müdür</span> }
                            else if (User.IsInRole("Gise")) { <span class="badge bg-primary rounded-pill">Gişe</span> }
                            else if (User.IsInRole("Kurye")) { <span class="badge bg-success rounded-pill">Kurye</span> }
                        </small>
                    </div>
                    <i class="bi bi-person-circle fs-2 text-secondary shadow-sm rounded-circle"></i>
                </div>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @* --- DÜZELTİLEN KRİTİK SATIR BURASI --- *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>