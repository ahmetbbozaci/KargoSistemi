<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Personel Yönetim Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
       
        .sidebar { min-height: 100vh; background-color: #212529; }
        .sidebar a, .sidebar button { 
            color: #adb5bd; 
            text-decoration: none; 
            padding: 15px 20px; 
            display: block; 
            border-bottom: 1px solid #343a40; 
            transition: 0.3s;
            width: 100%;
            text-align: left;
            background: none;
            border-left: none;
            border-right: none;
            border-top: none;
        }
        .sidebar a:hover, .sidebar button:hover { background-color: #343a40; color: #fff; }
        .sidebar .active { background-color: #0d6efd; color: white; border-color: #0d6efd; }
        
        /* Çıkış butonu özel stili */
        .logout-btn { color: #dc3545 !important; }
        .logout-btn:hover { background-color: #842029 !important; color: #fff !important; }
    </style>
</head>
<body class="bg-light">

    <div class="d-flex">
        <div class="sidebar text-white flex-shrink-0" style="width: 250px;">
            <div class="p-3 text-center border-bottom border-secondary">
                <h5 class="fw-bold mb-0">MERKEZ KARGO</h5>
                <small class="text-muted">Personel Paneli</small>
            </div>
            <nav class="nav flex-column mt-3">
                <a asp-controller="Admin" asp-action="Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-speedometer2 me-2"></i> Gösterge Paneli
                </a>
                <a href="#"><i class="bi bi-box-seam me-2"></i> Yeni Kargo Kabulü</a>
                <a href="#"><i class="bi bi-arrow-left-right me-2"></i> Durum Güncelleme</a>
                <a href="#"><i class="bi bi-bar-chart-fill me-2"></i> Gelir & Yoğunluk Raporları</a>
                
                <a asp-controller="Admin" asp-action="PersonelEkle" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "PersonelEkle" ? "active" : "")">
                    <i class="bi bi-person-add me-2"></i> Yeni Personel Ekle
                </a>
                
                <form asp-controller="Auth" asp-action="Logout" method="post" class="mt-5 border-top border-secondary">
                    <button type="submit" class="logout-btn">
                        <i class="bi bi-box-arrow-left me-2"></i> Güvenli Çıkış
                    </button>
                </form>
            </nav>
        </div>

        <div class="flex-grow-1 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h3 class="fw-bold text-dark m-0">@ViewData["Title"]</h3>
                
                <div class="d-flex align-items-center">
                    <div class="text-end me-3">
                        <div class="fw-bold text-primary">@ViewBag.SubeAdi</div>
                        <small class="text-muted">Personel: @User.Identity?.Name</small>
                    </div>
                    <i class="bi bi-person-circle fs-3 text-secondary"></i>
                </div>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>