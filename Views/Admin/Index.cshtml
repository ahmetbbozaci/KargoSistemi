@{
    ViewData["Title"] = "Gösterge Paneli";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; 
}

<!-- YENİ EKLENEN KISIM: Karşılama Alanı ve Hızlı Aksiyon Butonu -->
<div class="d-flex justify-content-between align-items-end mb-4 pb-2 border-bottom">
    <div>
        <h3 class="fw-bold mb-2" style="color: #1a2b3c;">Hoş Geldin, @ViewBag.AdminAdi</h3>
        <span class="badge bg-secondary px-3 py-2 rounded-pill shadow-sm">
            <i class="bi bi-building-gear me-1"></i> @ViewBag.SubeAdi Yetkilisi
        </span>
    </div>
    <div>
        <a asp-controller="Admin" asp-action="PersonelEkle" class="btn btn-dark rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-person-plus-fill me-2"></i> Yeni Personel Ekle
        </a>
    </div>
</div>

<!-- Mevcut İstatistik Kartları (İleride SQL'den beslenecek simülasyon verileri) -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100" style="background-color: #1a2b3c; color: white;">
            <div class="card-body p-4">
                <h6 class="card-title text-uppercase text-white-50 fw-bold mb-3"><i class="bi bi-box-seam me-2"></i>Günlük Kargo Çıkışı</h6>
                <h2 class="display-5 fw-bold mb-0">142 <small class="fs-6 fw-normal text-white-50">Adet</small></h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100" style="background-color: #2c3e50; color: white;">
            <div class="card-body p-4">
                <h6 class="card-title text-uppercase text-white-50 fw-bold mb-3"><i class="bi bi-wallet2 me-2"></i>Günlük Toplam Gelir</h6>
                <h2 class="display-5 fw-bold mb-0">₺18.450</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100 bg-light border-start border-5 border-dark">
            <div class="card-body p-4">
                <h6 class="card-title text-uppercase text-muted fw-bold mb-3"><i class="bi bi-signpost-split me-2"></i>En Çok Kullanılan Hat</h6>
                <h2 class="display-6 fw-bold text-dark mb-0">Ankara - İst.</h2>
            </div>
        </div>
    </div>
</div>

<!-- Son İşlemler Tablosu -->
<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 border-bottom">
        <h5 class="mb-0 fw-bold" style="color: #1a2b3c;"><i class="bi bi-clock-history me-2"></i>Son İşlem Gören Kargolar</h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light text-muted">
                <tr>
                    <th class="ps-4">Takip No</th>
                    <th>Gönderici</th>
                    <th>Alıcı</th>
                    <th>Çıkış Şubesi</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="ps-4"><span class="badge bg-light text-dark border">TR849201</span></td>
                    <td class="fw-medium">Ahmet Yılmaz</td>
                    <td>Mehmet Demir</td>
                    <td>Ankara Merkez</td>
                    <td><span class="badge bg-primary rounded-pill">Yolda</span></td>
                </tr>
                <tr>
                    <td class="ps-4"><span class="badge bg-light text-dark border">TR849202</span></td>
                    <td class="fw-medium">Ayşe Kaya</td>
                    <td>Fatma Çelik</td>
                    <td>İstanbul Avrupa</td>
                    <td><span class="badge bg-success rounded-pill">Teslim Edildi</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>