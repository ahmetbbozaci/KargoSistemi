@{
    ViewData["Title"] = "Gösterge Paneli";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Personel iskeletini kullanmasını söylüyoruz
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-primary text-white h-100">
            <div class="card-body">
                <h6 class="card-title text-uppercase text-white-50">Günlük Toplam Gönderi</h6>
