@{
    ViewData["Title"] = "Ücret Hesapla";
}

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            
            <div class="text-center mb-4">
                <h2 class="fw-bold text-dark">Gönderi Ücreti Hesaplama</h2>
                <p class="text-muted">Ağırlık, hacim ve mesafe bilgilerini girerek tahmini taşıma bedelini öğrenebilirsiniz.</p>
                <div class="mx-auto bg-danger rounded mb-4" style="height: 4px; width: 60px;"></div>
            </div>
            
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <form method="post" asp-controller="Hesaplama" asp-action="Index">
                        
                        <div class="row mb-4 g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Ağırlık (Kg)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-box-seam text-muted"></i></span>
                                    <input type="number" step="0.1" name="kg" class="form-control border-start-0 bg-light" required placeholder="0.0">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Gönderim Hattı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-signpost-split text-muted"></i></span>
                                    <select name="hat" class="form-select border-start-0 bg-light" required>
                                        <option value="">Seçiniz...</option>
                                        <option value="SehirIci">Şehir İçi</option>
                                        <option value="Kisa">Kısa Hat (Komşu Şehirler)</option>
                                        <option value="Orta">Orta Hat</option>
                                        <option value="Uzak">Uzak Hat</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <label class="form-label fw-bold text-secondary small text-uppercase mb-3">Hacim Hesaplama (Desi İçin)</label>
                        <div class="row mb-4 g-3">
                            <div class="col-md-4">
                                <input type="number" name="en" class="form-control bg-light" required placeholder="En (cm)">
                            </div>
                            <div class="col-md-4">
                                <input type="number" name="boy" class="form-control bg-light" required placeholder="Boy (cm)">
                            </div>
                            <div class="col-md-4">
                                <input type="number" name="yukseklik" class="form-control bg-light" required placeholder="Yükseklik (cm)">
                            </div>
                        </div>

                        <div class="d-grid mt-2">
                            <button type="submit" class="btn btn-dark btn-lg fw-bold rounded-3">Fiyat Hesapla</button>
                        </div>
                    </form>
                </div>
            </div>

            @if (ViewBag.SonucGoster != null && ViewBag.SonucGoster == true)
            {
                <div class="card shadow border-0 mt-4 border-top border-danger border-4 rounded-3 bg-light">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-md-7 border-end">
                                <h5 class="fw-bold mb-3">Hesaplama Özeti</h5>
                                <p class="mb-1 text-muted">Girilen Ağırlık: <strong class="text-dark">@ViewBag.Kg kg</strong></p>
                                <p class="mb-1 text-muted">Hacimsel Ağırlık (Desi): <strong class="text-dark">@ViewBag.Desi</strong></p>
                                <p class="mb-0 mt-2 text-danger small"><i class="bi bi-info-circle-fill me-1"></i>Fiyatlandırmada @ViewBag.EsasAgirlik değeri (yüksek olan) baz alınmıştır.</p>
                            </div>
                            <div class="col-md-5 text-center">
                                <span class="text-muted text-uppercase small fw-bold">Tahmini Tutar</span>
                                <h2 class="display-5 fw-bold text-dark mb-0">@ViewBag.Tutar <span class="fs-4 text-muted">TL</span></h2>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>